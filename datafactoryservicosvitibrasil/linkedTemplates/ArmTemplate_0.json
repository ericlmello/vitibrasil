		"servicovinculadoDataLakevitibrasil_accountKey": {
			"type": "secureString",
			"metadata": "Cadeia de caracteres segura para 'accountKey' de 'servicovinculadoDataLakevitibrasil'"
		},
		"servicovinculadoDataLakevitibrasil_properties_typeProperties_url": {
