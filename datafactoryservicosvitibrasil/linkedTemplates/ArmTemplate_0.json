				"schema": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/servicovinculadoDataLakevitibrasil')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/datasetfontevitibrasil')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "servicovinculadoDFvitibrasil",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "DelimitedText",
				"typeProperties": {
					"location": {
						"type": "AzureBlobStorageLocation",
						"fileName": "arquivos_csv.zip",
						"container": "containervitibrasil"
