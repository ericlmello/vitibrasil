				"typeProperties": {
					"url": "[parameters('servicovinculadoDataLakevitibrasil_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('servicovinculadoDataLakevitibrasil_accountKey')]"
					}
				}
			},
			"dependsOn": []
